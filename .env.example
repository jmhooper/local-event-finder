# I use LiteLLM to proxy requests to LLMs. Configure the API host and key here
LITELLM_API_HOST=
LITELLM_API_KEY=

# Postgres connection string used by Prisma and pg-boss.
# Example: postgresql://user:password@localhost:5432/local_event_aggregator
DATABASE_URL=

# Optional: port for the Express API (default 3000)
# PORT=3000

# Optional: timezone used for cron schedules (default America/New_York)
# SCHEDULE_TZ=America/New_York
